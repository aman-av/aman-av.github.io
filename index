<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #ffffff;
    --surface: #f7f8fa;
    --border: #e5e7eb;
    --text: #1f2328;
    --muted: #57606a;
    --accent: #3b82d4;
    --accent2: #7c5cd8;
    --radius: 10px;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: -apple-system, "Segoe UI", system-ui, sans-serif;
    font-size: 15px;
    line-height: 1.65;
    color: var(--text);
    background: var(--bg);
  }

  /* ── NAV ── */
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.92);
    backdrop-filter: blur(6px);
    border-bottom: 1px solid var(--border);
    padding: 0 24px;
  }
  nav .inner {
    max-width: 760px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 52px;
  }
  nav .logo {
    font-weight: 700;
    font-size: 16px;
    letter-spacing: 0.02em;
    color: var(--text);
    text-decoration: none;
  }
  nav ul {
    list-style: none;
    display: flex;
    gap: 24px;
  }
  nav ul a {
    text-decoration: none;
    color: var(--muted);
    font-size: 13.5px;
    font-weight: 500;
    transition: color 0.15s;
  }
  nav ul a:hover { color: var(--accent); }

  /* ── LAYOUT ── */
  .wrap {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 24px;
  }

  section { padding: 64px 0; }
  section + section { border-top: 1px solid var(--border); }

  h1 { font-size: 2.4rem; font-weight: 800; letter-spacing: -0.02em; line-height: 1.2; }
  h2 { font-size: 1.25rem; font-weight: 700; margin-bottom: 28px; color: var(--text); }
  h3 { font-size: 1rem; font-weight: 700; }

  /* ── HERO ── */
  #hero { padding-top: 80px; padding-bottom: 72px; }
  .hero-tag {
    display: inline-block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    font-size: 12.5px;
    font-weight: 600;
    color: var(--accent);
    padding: 3px 12px;
    margin-bottom: 20px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .hero-sub {
    font-size: 1.1rem;
    color: var(--muted);
    margin-top: 14px;
    max-width: 560px;
  }
  .hero-links {
    margin-top: 28px;
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 9px 20px;
    border-radius: 8px;
    font-size: 13.5px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: opacity 0.15s;
  }
  .btn:hover { opacity: 0.82; }
  .btn-primary { background: var(--accent); color: #fff; }
  .btn-outline {
    background: transparent;
    border: 1.5px solid var(--border);
    color: var(--text);
  }
  .contact-strip {
    margin-top: 32px;
    display: flex;
    gap: 24px;
    flex-wrap: wrap;
    font-size: 13px;
    color: var(--muted);
  }
  .contact-strip span { display: flex; align-items: center; gap: 6px; }
  .contact-strip a { color: var(--muted); text-decoration: none; }
  .contact-strip a:hover { color: var(--accent); }

  /* ── ABOUT ── */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }
  .about-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 22px;
  }
  .about-card .label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
    margin-bottom: 8px;
  }
  .about-card .value {
    font-size: 14.5px;
    color: var(--text);
    font-weight: 600;
  }
  .about-card .value.muted { font-weight: 400; color: var(--muted); }

  /* ── EXPERIENCE ── */
  .timeline { display: flex; flex-direction: column; gap: 0; }
  .tl-item {
    position: relative;
    padding-left: 28px;
    padding-bottom: 36px;
  }
  .tl-item:last-child { padding-bottom: 0; }
  .tl-item::before {
    content: "";
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 0;
    width: 1px;
    background: var(--border);
  }
  .tl-item:last-child::before { display: none; }
  .tl-dot {
    position: absolute;
    left: 0;
    top: 6px;
    width: 15px;
    height: 15px;
    border-radius: 50%;
    background: var(--accent);
    border: 2.5px solid #fff;
    outline: 1.5px solid var(--border);
  }
  .tl-dot.purple { background: var(--accent2); }
  .tl-dot.gray { background: var(--muted); }
  .tl-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 12px; flex-wrap: wrap; }
  .tl-company { font-size: 13px; color: var(--accent); font-weight: 600; margin-bottom: 2px; }
  .tl-role { font-size: 15px; font-weight: 700; }
  .tl-stack { font-size: 12.5px; color: var(--muted); margin-top: 2px; }
  .tl-date { font-size: 12.5px; color: var(--muted); white-space: nowrap; }
  .tl-location { font-size: 12px; color: var(--muted); }
  .tl-body { margin-top: 10px; }
  .tl-body ul { list-style: none; padding: 0; display: flex; flex-direction: column; gap: 6px; }
  .tl-body ul li {
    position: relative;
    padding-left: 14px;
    font-size: 13.5px;
    color: #374151;
    line-height: 1.6;
  }
  .tl-body ul li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: var(--border);
    font-size: 11px;
    top: 2px;
  }
  .tl-body ul li strong { color: var(--text); }

  /* ── SKILLS ── */
  .skills-grid { display: flex; flex-direction: column; gap: 18px; }
  .skill-row { }
  .skill-label { font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.07em; color: var(--muted); margin-bottom: 8px; }
  .chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 13px;
    font-weight: 500;
    color: var(--text);
  }
  .chip.accent { border-color: #bfdbfe; background: #eff6ff; color: #1d4ed8; }
  .chip.purple { border-color: #ddd6fe; background: #f5f3ff; color: #5b21b6; }

  /* ── EDUCATION ── */
  .edu-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px 28px;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    flex-wrap: wrap;
  }
  .edu-card .inst { font-size: 16px; font-weight: 700; }
  .edu-card .degree { font-size: 13.5px; color: var(--muted); margin-top: 4px; }
  .edu-card .cgpa {
    font-size: 13px;
    font-weight: 600;
    color: var(--accent);
    margin-top: 6px;
  }
  .edu-card .date { font-size: 12.5px; color: var(--muted); text-align: right; }

  /* ── HIGHLIGHTS ── */
  .highlights { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
  .hl-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 22px;
    text-align: center;
  }
  .hl-card .num { font-size: 2rem; font-weight: 800; color: var(--accent); line-height: 1; }
  .hl-card .num.purple { color: var(--accent2); }
  .hl-card .desc { font-size: 12.5px; color: var(--muted); margin-top: 6px; line-height: 1.4; }

  /* ── FOOTER ── */
  footer {
    border-top: 1px solid var(--border);
    padding: 20px 24px;
    text-align: center;
    font-size: 12px;
    color: var(--muted);
  }
  footer a { color: var(--muted); text-decoration: none; }
  footer a:hover { color: var(--accent); }
  .made-with {
    border-top: 1px solid var(--border);
    margin-top: 16px;
    padding-top: 16px;
    font-size: 11.5px;
    color: #adb5bd;
    text-align: center;
  }

  @media (max-width: 600px) {
    h1 { font-size: 1.8rem; }
    .about-grid { grid-template-columns: 1fr; }
    .highlights { grid-template-columns: 1fr 1fr; }
    .tl-header { flex-direction: column; gap: 2px; }
  }
</style>
